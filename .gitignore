# Ignore Go build artifacts
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
out/


pg_data/
# Ignore directories
vendor/

# Ignore IDE/editor config files
.idea/
.vscode/
*.swp

# Ignore logs
*.log

# Ignore environment files
.env

# Ignore database files
*.db
*.sqlite3

# Ignore macOS system files
.DS_Store

.last-sync-checksum

# Ignore backup files.
*~
# Ignore Vim swap files.
.*.swp
# macOS-specific excludes
.DS_Store
# Ignore files generated by IDEs.
/.aswb/
/.bazelbsp/
/.cache/
/.classpath
/.clwb/
/.factorypath
/.idea/
/.ijwb/
/.project
/.settings
/.vscode/
.eclipse/
.settings/
.classpath
.project
eclipse-*bin/
/bazel.iml
# Ignore all bazel-* symlinks. There is no full list since this can change
# based on the name of the directory bazel is cloned into.
/bazel-*
# Ignore outputs generated during Bazel bootstrapping.
/output/
# Ignore jekyll build output.
/production
/.sass-cache
# Bazelisk version file
.bazelversion
# User-specific .bazelrc
user.bazelrc
.terraform/
.terragrunt-cache/
*.tfstate
*.tfstate.backup
*.tfvars

# Helm chart dependencies (downloaded charts, not custom charts)
**/charts/*/charts/

# Compiled binary
/native
